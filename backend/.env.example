# ─────────────────────────────────────────────────────────────────
#  LibraFlow — Variables d'environnement (TEMPLATE)
#  Copiez ce fichier en .env et remplissez les valeurs réelles.
#  Ne committez JAMAIS le fichier .env dans git.
# ─────────────────────────────────────────────────────────────────

# Port du serveur Express
PORT=5000

# Environnement (development | production)
NODE_ENV=development

# URI de connexion MongoDB Atlas
# Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/libraflow

# Secret JWT — doit être une chaîne aléatoire longue (min 64 chars)
# Générer avec : openssl rand -hex 64
JWT_SECRET=REMPLACER_PAR_UNE_LONGUE_CHAINE_ALEATOIRE_MIN_64_CHARS

# Durée de validité des tokens JWT
JWT_EXPIRES_IN=7d

# Clé API Groq (LLaMA 3.3) — https://console.groq.com
# Laisser vide pour utiliser les réponses de fallback
GROQ_API_KEY=

# URL du frontend autorisée (CORS)
# En dev : http://localhost:5173
# En prod : https://votre-app.vercel.app
FRONTEND_URL=http://localhost:5173
